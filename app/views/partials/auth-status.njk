<div class="auth-status {{ 'ok' if auth.signedIn else 'warn' }}">
  {% if auth.signedIn %}
    <div>
      <div>Signed in as <strong>{{ auth.user }}</strong></div>
      <div class="muted">Tenant: <code>{{ auth.tenantId }}</code> · Subscription: <code>{{ auth.subscription }}</code> ({{ auth.subscriptionId }})</div>
    </div>
    <button class="btn danger" hx-post="/api/auth/logout" hx-swap="none">Sign out</button>
  {% else %}
    <div>Not signed in.</div>
    {% if login.active %}
      <div class="muted">Device-code flow in progress… <span>{{ login.lastMessage }}</span></div>
      <button class="btn" hx-post="/api/auth/cancel" hx-swap="none">Cancel</button>
    {% else %}
      <button class="btn primary" hx-post="/api/auth/login" hx-swap="none">Sign in with device code</button>
    {% endif %}
  {% endif %}
</div>
{% if login.finished and not login.success %}
  <div class="error">Last sign-in attempt failed: {{ login.lastMessage }}</div>
{% endif %}
